# --- PLATFORM CREDENTIALS ---
# Your primary Groq API key for administrative tasks or fallbacks
GROQ_API_KEY=gsk_your_platform_key_here

# --- SECURITY ---
# A 32-byte base64-encoded key for encrypting user API keys at rest.
# You can generate one using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here
